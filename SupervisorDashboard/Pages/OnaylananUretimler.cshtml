@page
@model SupervisorDashboard.Pages.OnaylananUretimlerModel
@{
    ViewData["Title"] = "Onaylanan Üretimler Detayı";
}

<div class="container-fluid py-4" style="min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="fw-bold" style="color: #2b3e50;"><i class="bi bi-check-circle-fill text-success"></i> Onaylanan Üretimler Geçmişi</h2>
            <p class="text-muted m-0">Tüm üretim bantlarından tamamlanmış ve onaylanmış akü üretimlerinin tam listesi</p>
        </div>
        <div>
            <a href="/" class="btn btn-outline-secondary fw-bold shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Dashboard'a Dön
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Tamamlanma Tarihi</th>
                        <th>Akü Tipi / Stok</th>
                        <th>Üretilen Miktar</th>
                        <th>Çıktığı Bant</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.TamamlananUretimler.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-2"></i>
                                <p class="mb-0 mt-2">Kayıt bulunamadı.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var islem in Model.TamamlananUretimler)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@islem.IslemZamani.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="fw-bold"><i class="bi bi-battery-charging text-success me-2"></i>@islem.StokKodu</td>
                                <td><span class="fw-bold text-success">@islem.Miktar</span> Adet</td>
                                <td><span class="badge bg-dark">@islem.HedefBant</span></td>
                                <td><span class="badge bg-success"><i class="bi bi-check-all me-1"></i>Tamamlandı</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
