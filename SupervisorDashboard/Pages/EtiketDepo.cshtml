@page
@model SupervisorDashboard.Pages.EtiketDepoModel
@{
    ViewData["Title"] = "Etiket Depo Sevkiyatları Detayı";
}

<div class="container-fluid py-4" style="min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="fw-bold" style="color: #2b3e50;"><i class="bi bi-tags-fill text-primary"></i> Etiket Depo Sevkiyat Geçmişi</h2>
            <p class="text-muted m-0">Tüm etiket transfer ve sipariş işlemleri detaylı listesi</p>
        </div>
        <div>
            <a href="/" class="btn btn-outline-secondary fw-bold shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Dashboard'a Dön
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Tarih</th>
                        <th>Firma / Marka</th>
                        <th>Miktar</th>
                        <th>Hedef Bant</th>
                        <th>Taşıyıcı Araç</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.EtiketIslemleri.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-2"></i>
                                <p class="mb-0 mt-2">Kayıt bulunamadı.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var islem in Model.EtiketIslemleri)
                        {
                            var durumRenk = islem.IslemDurumu switch {
                                "Tamamlandı" => "bg-success",
                                "Transferde" => "bg-warning text-dark",
                                "İptal Edildi" => "bg-danger",
                                _ => "bg-secondary"
                            };

                            <tr>
                                <td class="ps-4 text-muted small">@islem.IslemZamani.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="fw-bold"><i class="bi bi-tag-fill text-primary me-2"></i>@islem.FirmaMarkasi</td>
                                <td><span class="fw-bold">@islem.Miktar</span> Adet</td>
                                <td><span class="badge bg-dark">@islem.HedefBant</span></td>
                                <td><i class="bi bi-truck text-success me-1"></i> @islem.TasiyiciAracId</td>
                                <td><span class="badge @durumRenk">@islem.IslemDurumu</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
