<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>

<script>
// ===== BANT LOJİSTİK AKIŞ: Sayfa açılınca DB'den çek =====
function bantAkisGuncelle(bant) {
    fetch(`/MamulDepo/BantIslemleri?bant=${encodeURIComponent(bant)}`)
        .then(r => r.json())
        .then(data => {
            const akisEl = document.getElementById(`akis_${bant}`);
            const detayBtn = document.getElementById(`detayBtn_${bant}`);

            if (data && data.length > 0) {
                const activeIslemler = data.filter(x => x.islemDurumu === 'Beklemede' || x.islemDurumu === 'Üretiliyor');
                const activeCount = activeIslemler.length;
                
                if (akisEl) {
                    if (activeCount > 0) {
                        akisEl.innerHTML = `<span class="text-success fw-bold"><i class="bi bi-lightning-charge-fill me-1"></i>VAR (${activeCount} Akü)</span>`;
                    } else {
                        akisEl.innerHTML = `<span class="text-muted">Yok</span>`;
                    }
                }
                
                if (detayBtn) detayBtn.removeAttribute('hidden');
                
                // Eğer üretime alınmış akü varsa, bandı meşgul yap ve sayacı başlat
                const uretilenler = data.filter(x => x.islemDurumu === 'Üretiliyor');
                if (uretilenler.length > 0) {
                    const firstIslem = uretilenler[0];
                    if (window.bandStates && window.bandStates[bant]) {
                        const bState = window.bandStates[bant];
                        if (!bState.busySince) {
                            // islemZamani ISO formatındadır
                            const past = new Date(firstIslem.islemZamani).getTime();
                            bState.busySince = past;
                            const diff = Math.floor((Date.now() - past) / 10000);
                            bState.totalProduced = diff > 0 && !isNaN(diff) ? diff : 0;
                            bState.targetProduced = firstIslem.miktar || 500;
                            
                            // UI'ı MEŞGUL yap
                            const statusEl = document.getElementById(`status_${bant}`);
                            if (statusEl) {
                                statusEl.innerText = "MEŞGUL";
                                statusEl.className = "fs-4 fw-bold text-warning animate__animated animate__flash animate__repeat-2";
                            }
                            const progressEl = document.getElementById(`progress_${bant}`);
                            if (progressEl) {
                                progressEl.className = "progress-bar bg-warning progress-bar-striped progress-bar-animated";
                                progressEl.style.width = "100%";
                            }
                            const logisticEl = document.getElementById(`logistic_${bant}`);
                            if (logisticEl) {
                                logisticEl.innerHTML = `<i class="bi bi-gear-fill text-warning me-1"></i> İşlem: <span class="text-warning fw-bold">Seri Üretim (${bState.totalProduced} / ${bState.targetProduced} akü üretildi)</span>`;
                            }
                        }
                    }
                }
            } else {
                if (akisEl) akisEl.innerHTML = `<span class="text-muted">Yok</span>`;
                if (detayBtn) detayBtn.setAttribute('hidden', '');
            }
        })
        .catch(() => {
            const akisEl = document.getElementById(`akis_${bant}`);
            if (akisEl) akisEl.innerHTML = `<span class="text-muted">—</span>`;
        });
}

// Sayfa yüklenince tüm bantları sorgula
['BANT-1', 'BANT-2', 'BANT-3'].forEach(bantAkisGuncelle);

// ===== BANT DETAY MODAL =====
window.bantDetayGoster = function(bant) {
    document.getElementById('bantDetayBaslik').innerText = `${bant} — Akü ve İşlem Listesi`;
    document.getElementById('bantDetayYukleniyor').style.display = '';
    document.getElementById('bantDetayIcerik').style.display = 'none';
    document.getElementById('bantDetayBos').style.display = 'none';

    if (window.bandStates) {
        window.currentActiveModalBand = bant;
        const bState = window.bandStates[bant];
        if (bState) {
            document.getElementById('modalWorkerName').innerText = bState.worker || 'Bilinmiyor';
            document.getElementById('modalCurrentTask').innerText = bState.busySince ? 'Montaj / Test Aşamasında' : 'Beklemede';
            document.getElementById('modalActiveTimer').innerText = bState.timerDisplay || '00:00';
            document.getElementById('modalProdCount').innerText = bState.busySince ? `${bState.totalProduced || 0} / ${bState.targetProduced || 500}` : '0 / 500';
            document.getElementById('modalCurrentTask').className = bState.busySince ? 'fw-bold text-warning' : 'fw-bold text-success';
        }
    }

    const modal = new bootstrap.Modal(document.getElementById('bantDetayModal'));
    modal.show();


    fetch(`/MamulDepo/BantIslemleri?bant=${encodeURIComponent(bant)}`)
        .then(r => r.json())
        .then(data => {
            document.getElementById('bantDetayYukleniyor').style.display = 'none';
            const tablo = document.getElementById('bantDetayTablo');
            tablo.innerHTML = '';

            if (!data || data.length === 0) {
                document.getElementById('bantDetayBos').style.display = '';
                return;
            }

            data.forEach(item => {
                let badgeClass = 'bg-success';
                let textClass = '';
                if (item.islemDurumu === 'Beklemede') {
                    badgeClass = 'bg-warning';
                    textClass = 'text-dark';
                } else if (item.islemDurumu === 'İptal Edildi') {
                    badgeClass = 'bg-danger';
                }

                const durumBadge = `<span class="badge ${badgeClass} ${textClass}">${item.islemDurumu}</span>`;

                tablo.innerHTML += `
                    <tr>
                        <td><code class="text-primary">${item.stokKodu || '—'}</code></td>
                        <td class="fw-semibold">${item.malzemeAciklamasi || '—'}</td>
                        <td><span class="badge bg-secondary">${item.lokasyonNo || '—'}</span></td>
                        <td><strong>${item.ulkeSeriNo || '—'}</strong></td>
                        <td>${durumBadge}</td>
                        <td class="text-muted small">${item.islemZamani}</td>
                    </tr>`;
            });

            document.getElementById('bantDetayIcerik').style.display = '';
        });
};

// ===== SignalR: Yeni işlem eklenince bantları otomatik güncelle =====
document.addEventListener('mamulDepoYeniIslem', function(e) {
    const bant = e.detail && e.detail.hedef_bant;
    if (bant) bantAkisGuncelle(bant);
});
</script>

