@page
@model IndexModel
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Etiketleme Amirliği Kontrol Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
</head>
<body style="background-color: #f4f6f9;">

<div class="container-fluid py-4" style="min-height: 100vh;">
    <!-- Offcanvas Navbar/Sidebar -->
    <div class="offcanvas offcanvas-start shadow-lg" tabindex="-1" id="sidebarMenu" aria-labelledby="sidebarMenuLabel" style="width: 320px; border-right: none;">
        <div class="offcanvas-header text-white" style="background: linear-gradient(135deg, #2b3e50, #34495e); border-bottom: 3px solid #3498db;">
            <h5 class="offcanvas-title fw-bold d-flex align-items-center" id="sidebarMenuLabel">
                <i class="bi bi-cpu-fill text-info me-2"></i> SmartFactory
            </h5>
            <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0 d-flex flex-column bg-light">
            <div class="p-3">
                <p class="text-muted small fw-bold text-uppercase mb-2" style="letter-spacing: 0.5px;">Hızlı Kısayollar</p>
                <div class="nav flex-column nav-pills gap-2">
                    <button onclick="showSarjModal()" class="nav-link bg-white text-dark border shadow-sm fw-bold d-flex align-items-center py-2 px-3 text-start hover-lift" style="transition: transform 0.2s ease, box-shadow 0.2s ease;" data-bs-dismiss="offcanvas">
                        <div class="bg-warning bg-opacity-10 text-warning rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-lightning-charge-fill fs-5"></i>
                        </div>
                        Şarj İsteği Aç
                    </button>
                    <button onclick="showReportModal()" class="nav-link bg-white text-dark border shadow-sm fw-bold d-flex align-items-center py-2 px-3 text-start hover-lift" style="transition: transform 0.2s ease, box-shadow 0.2s ease;" data-bs-dismiss="offcanvas">
                        <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-pencil-square fs-5"></i>
                        </div>
                        Etiket Sipariş Aç
                    </button>
                    <a href="/Bant" class="nav-link bg-white text-dark border shadow-sm fw-bold d-flex align-items-center py-2 px-3 hover-lift" style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
                        <div class="bg-info bg-opacity-10 text-info rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-gear-fill fs-5"></i>
                        </div>
                        Bant Yönetimi
                    </a>
                    <a href="/MamulDepo" class="nav-link bg-white text-dark border shadow-sm fw-bold d-flex align-items-center py-2 px-3 hover-lift" style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
                        <div class="bg-secondary bg-opacity-10 text-secondary rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-archive-fill fs-5"></i>
                        </div>
                        Mamül Depo (Akü)
                    </a>
                    
                    <p class="text-muted small fw-bold text-uppercase mb-1 mt-2" style="letter-spacing: 0.5px;">Detaylı Raporlar</p>
                    
                    <a href="/EtiketDepo" class="nav-link bg-white text-dark border shadow-sm fw-bold d-flex align-items-center py-2 px-3 hover-lift" style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
                        <div class="bg-danger bg-opacity-10 text-danger rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-tags-fill fs-5"></i>
                        </div>
                        Etiket Sevkiyatları
                    </a>
                    
                    <a href="/OnaylananUretimler" class="nav-link bg-white text-dark border shadow-sm fw-bold d-flex align-items-center py-2 px-3 hover-lift" style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
                        <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-check-circle-fill fs-5"></i>
                        </div>
                        Onaylanan Üretimler
                    </a>
                </div>
            </div>

            <!-- Divider -->
            <hr class="my-1 border-secondary opacity-25">

            <!-- Recent Actions / Summary -->
            <div class="p-3 flex-grow-1 overflow-auto">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted small fw-bold text-uppercase mb-0" style="letter-spacing: 0.5px;">Son İşlem Özetleri</p>
                    <span class="badge bg-secondary rounded-pill" style="font-size: 0.65rem;" id="sidebarLogCount">0</span>
                </div>
                
                <div id="sidebarLogList" class="d-flex flex-column gap-2">
                    <div class="text-center text-muted my-4" id="sidebarEmptyState">
                        <i class="bi bi-clock-history fs-2 text-secondary mb-2 opacity-50"></i>
                        <p class="small fw-bold mb-0">Henüz bir işlem yok.</p>
                    </div>
                </div>
            </div>
            
            <div class="mt-auto p-3 bg-white border-top text-center text-muted" style="font-size: 0.75rem;">
                <i class="bi bi-shield-check text-success me-1"></i> Sistem durumu stabil
            </div>
        </div>
    </div>

    <!-- MAIN HEADER (Replaces old top-right buttons) -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center">
            <!-- Hamburger Button -->
            <button class="btn btn-outline-secondary border-0 me-3 shadow-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" style="font-size: 1.5rem;">
                <i class="bi bi-list"></i>
            </button>
            <div>
                <h2 class="fw-bold m-0" style="color: #2b3e50;"><i class="bi bi-activity text-primary"></i> SmartLogistics // Kontrol Merkezi</h2>
                <p class="text-muted m-0 ms-4" style="font-size:0.9rem;">Fabrika anlık etiketleme, depo ve hammadde senkronizasyon radarı</p>
            </div>
        </div>
        <div class="text-end">
            <div class="d-flex align-items-center justify-content-end gap-2">
                <span class="badge bg-success fw-bold px-3 py-2 shadow-sm" id="systemStatus" style="font-size:0.8rem; border-radius: 8px;">
                    <i class="bi bi-circle-fill me-1 animate__animated animate__flash animate__infinite animate__slower" style="font-size:0.5rem;"></i> Sistem Çevrimiçi
                </span>
            </div>
            <div class="text-muted fw-bold mt-2" id="liveClock" style="font-size:0.9rem;">Yükleniyor...</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- BANT-1 KARTI -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 5px solid #2b3e50 !important;" id="card_BANT-1">
                <div class="card-body p-3 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="card-title text-uppercase fw-bold mb-0" style="color:#2b3e50; font-size:0.78rem;">ÜRETİM NOKTASI (BANT-1)</h6>
                            <div class="small text-muted mt-1"><i class="bi bi-person-badge text-primary"></i> Sorumlu: <strong>Ahmet Yılmaz</strong></div>
                        </div>
                        <span class="badge bg-secondary" id="badge_BANT-1" style="font-size:0.7rem;">B1-OK</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold text-success" style="font-size:1.1rem;" id="status_BANT-1">AKTİF (Boşta)</span>
                        <span class="small text-muted fw-bold" id="timer_BANT-1">⏱ 00:00</span>
                    </div>

                    <!-- Üretim İlerleme Barı -->
                    <div class="mb-1" style="font-size:0.72rem;" id="prodCount_BANT-1"></div>
                    <div class="progress mb-3" style="height: 8px;">
                        <div id="progress_BANT-1" class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                    </div>

                    <!-- Lojistik / Aksiyon Bölümü -->
                    <div class="mt-auto pt-2 border-top" style="font-size: 0.8rem;">
                        <div id="logistic_BANT-1">
                            <span class="text-muted"><i class="bi bi-pause-circle me-1"></i> Bekleniyor...</span>
                        </div>
                        <!-- Onayla + Detay satırı -->
                        <div class="d-flex justify-content-between align-items-center mt-2" id="actionRow_BANT-1" style="display:none !important;">
                            <div id="onaylaContainer_BANT-1"></div>
                            <button class="btn btn-outline-secondary py-0 px-2" style="font-size:0.75rem;" onclick="bantDetayGoster('BANT-1')">
                                <i class="bi bi-search me-1"></i>Detay
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- BANT-2 KARTI -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 5px solid #2b3e50 !important;" id="card_BANT-2">
                <div class="card-body p-3 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="card-title text-uppercase fw-bold mb-0" style="color:#2b3e50; font-size:0.78rem;">ÜRETİM NOKTASI (BANT-2)</h6>
                            <div class="small text-muted mt-1"><i class="bi bi-person-badge text-primary"></i> Sorumlu: <strong>Burak Can</strong></div>
                        </div>
                        <span class="badge bg-secondary" id="badge_BANT-2" style="font-size:0.7rem;">B2-OK</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold text-success" style="font-size:1.1rem;" id="status_BANT-2">AKTİF (Boşta)</span>
                        <span class="small text-muted fw-bold" id="timer_BANT-2">⏱ 00:00</span>
                    </div>

                    <!-- Üretim İlerleme Barı -->
                    <div class="mb-1" style="font-size:0.72rem;" id="prodCount_BANT-2"></div>
                    <div class="progress mb-3" style="height: 8px;">
                        <div id="progress_BANT-2" class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                    </div>

                    <!-- Lojistik / Aksiyon Bölümü -->
                    <div class="mt-auto pt-2 border-top" style="font-size: 0.8rem;">
                        <div id="logistic_BANT-2">
                            <span class="text-muted"><i class="bi bi-pause-circle me-1"></i> Bekleniyor...</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2" id="actionRow_BANT-2" style="display:none !important;">
                            <div id="onaylaContainer_BANT-2"></div>
                            <button class="btn btn-outline-secondary py-0 px-2" style="font-size:0.75rem;" onclick="bantDetayGoster('BANT-2')">
                                <i class="bi bi-search me-1"></i>Detay
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- BANT-3 KARTI -->
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 5px solid #2b3e50 !important;" id="card_BANT-3">
                <div class="card-body p-3 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="card-title text-uppercase fw-bold mb-0" style="color:#2b3e50; font-size:0.78rem;">ÜRETİM NOKTASI (BANT-3)</h6>
                            <div class="small text-muted mt-1"><i class="bi bi-person-badge text-primary"></i> Sorumlu: <strong>Hasan Şahin</strong></div>
                        </div>
                        <span class="badge bg-secondary" id="badge_BANT-3" style="font-size:0.7rem;">B3-OK</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold text-success" style="font-size:1.1rem;" id="status_BANT-3">AKTİF (Boşta)</span>
                        <span class="small text-muted fw-bold" id="timer_BANT-3">⏱ 00:00</span>
                    </div>

                    <!-- Üretim İlerleme Barı -->
                    <div class="mb-1" style="font-size:0.72rem;" id="prodCount_BANT-3"></div>
                    <div class="progress mb-3" style="height: 8px;">
                        <div id="progress_BANT-3" class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                    </div>

                    <!-- Lojistik / Aksiyon Bölümü -->
                    <div class="mt-auto pt-2 border-top" style="font-size: 0.8rem;">
                        <div id="logistic_BANT-3">
                            <span class="text-muted"><i class="bi bi-pause-circle me-1"></i> Bekleniyor...</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2" id="actionRow_BANT-3" style="display:none !important;">
                            <div id="onaylaContainer_BANT-3"></div>
                            <button class="btn btn-outline-secondary py-0 px-2" style="font-size:0.75rem;" onclick="bantDetayGoster('BANT-3')">
                                <i class="bi bi-search me-1"></i>Detay
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <div class="row g-3 mb-4">
        <!-- ETİKET DEPO SEVKİYATLARI -->
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 5px solid #18bc9c !important;">
                <div class="card-body p-3 d-flex flex-column">
                    <h6 class="card-title text-uppercase fw-bold mb-2" style="color:#18bc9c; font-size:0.78rem;"><i class="bi bi-tags-fill me-1"></i>Etiket Depo Sevkiyatları</h6>
                    @{
                        var aktifEtiketler = ViewData["AktifEtiketler"] as List<SupervisorDashboard.Models.EtiketDepoIslem>;
                    }
                    <div id="etiketListContainer" style="flex-grow: 1; max-height: 230px; overflow-y: auto; overflow-x: hidden;">
                        @if (aktifEtiketler == null || !aktifEtiketler.Any())
                        {
                            <div id="bosEtiketDurumu" class="text-center text-muted my-4">
                                <i class="bi bi-box-seam fs-1 text-light"></i>
                                <p class="mb-0 small fw-bold mt-2">Hazır / Görev Bekleniyor</p>
                            </div>
                        }
                        else
                        {
                            foreach (var etiket in aktifEtiketler)
                            {
                                <div id="etiketCard_@etiket.HedefBant" class="border rounded p-2 mb-2 shadow-sm position-relative">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="fw-bold text-success" style="font-size: 0.8rem;"><i class="bi bi-truck text-success"></i> @etiket.TasiyiciAracId</span>
                                        <span class="badge bg-secondary" style="font-size: 0.7rem;">@etiket.HedefBant</span>
                                    </div>
                                    <div class="small fw-bold mb-1"><i class="bi bi-tag-fill text-primary"></i> @etiket.FirmaMarkasi</div>
                                    <div class="d-flex justify-content-between small text-muted mb-1" style="font-size: 0.7rem;">
                                        <span>Etiket Miktarı:</span>
                                        <span class="fw-bold text-dark">@etiket.Miktar Adet</span>
                                    </div>
                                    <div class="progress mb-1" style="height: 4px;">
                                        <div class="progress-bar bg-info progress-bar-striped progress-bar-animated" role="progressbar" style="width: @etiket.KalanSeviyeYuzde%;"></div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- MAMÜL DEPO (Şarj Talepleri) -->
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 5px solid #8e44ad !important;">
                <div class="card-body p-3 d-flex flex-column">
                    <h6 class="card-title text-uppercase fw-bold mb-2" style="color:#8e44ad; font-size:0.78rem;"><i class="bi bi-lightning-charge-fill me-1"></i>Mamül Depo (Şarj)</h6>
                    <div id="mamulListContainer" style="flex-grow:1; max-height: 230px; overflow-y: auto; padding-right: 4px;">
                        @{
                            var mamuller = ViewData["AktifMamulIslemleri"] as List<SupervisorDashboard.Models.MamulDepoIslem>;
                            if (mamuller == null || !mamuller.Any())
                            {
                                <div id="bosMamulDurumu" class="text-center text-muted my-4">
                                    <i class="bi bi-box-seam fs-1 text-light"></i>
                                    <p class="mb-0 small fw-bold mt-2">Hazır / Görev Bekleniyor</p>
                                </div>
                            }
                            else
                            {
                                foreach (var islem in mamuller)
                                {
                                    bool isSarj = islem.IslemDurumu == "Şarj Bekliyor";
                                    var cardId = "mamulCard_" + islem.Id;
                                    var hedefGonderi = islem.LokasyonNo ?? "?";

                                    <div id="@cardId" class="border rounded p-2 mb-2 shadow-sm animate__animated animate__fadeInDown"
                                         style="@(isSarj ? "background-color: #fff8e1; border-color: #f39c12 !important;" : "")">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-bold @(isSarj ? "text-danger" : "text-primary")" style="font-size: 0.8rem;">
                                                <i class="bi @(isSarj ? "bi-lightning-charge-fill" : "bi-box-seam-fill")"></i>
                                                @(isSarj ? "Şarj İsteği" : "Akü Sevkiyatı")
                                            </span>
                                            <span class="badge @(isSarj ? "bg-warning text-dark" : "bg-info")" style="font-size: 0.65rem;">@islem.IslemDurumu</span>
                                        </div>
                                        <div class="small fw-bold mb-1">@islem.MalzemeAciklamasi</div>
                                        <div class="d-flex justify-content-between small text-muted" style="font-size: 0.7rem;">
                                            <span>Miktar:</span><span class="fw-bold text-dark">@islem.Miktar Adet</span>
                                        </div>
                                        @if (isSarj)
                                        {
                                            <div class="d-flex justify-content-between small text-muted mt-1" style="font-size: 0.7rem;">
                                                <span>Gönderilecek:</span><span class="fw-bold text-primary">@hedefGonderi</span>
                                            </div>
                                            <div class="mt-2 text-end">
                                                <button class="btn btn-sm btn-success px-2 py-0" style="font-size: 0.7rem; font-weight: bold;"
                                                        onclick="sarjaAl(@islem.Id, this)">
                                                    <i class="bi bi-check-circle me-1"></i> Şarja Al → @hedefGonderi
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ONAYLANAN ÜRETİMLER LİSTESİ -->
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm" style="border-left: 5px solid #27ae60 !important;">
                <div class="card-body p-3 d-flex flex-column">
                    <h6 class="card-title text-uppercase fw-bold mb-2" style="color:#27ae60; font-size:0.78rem;"><i class="bi bi-check-circle-fill me-1"></i>Onaylanan Üretimler</h6>
                    <div id="onaylananListContainer" style="flex-grow:1; max-height: 230px; overflow-y: auto; padding-right: 4px;">
                        @{
                            var tamamlananlar = ViewData["TamamlananUretimler"] as List<SupervisorDashboard.Models.MamulDepoIslem>;
                            if (tamamlananlar == null || !tamamlananlar.Any())
                            {
                                <div id="bosOnaylananDurumu" class="text-center text-muted my-4">
                                    <i class="bi bi-check-square fs-1 text-light"></i>
                                    <p class="mb-0 small fw-bold mt-2">Henüz Onaylanan Yok</p>
                                </div>
                            }
                            else
                            {
                                foreach (var islem in tamamlananlar)
                                {
                                    <div class="border rounded p-2 mb-2 shadow-sm animate__animated animate__fadeIn"
                                         style="background-color: #f0fff4; border-color: #27ae60 !important;">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-bold text-success" style="font-size: 0.78rem;">
                                                <i class="bi bi-check-all me-1"></i>@islem.HedefBant
                                            </span>
                                            <span class="badge bg-success" style="font-size: 0.65rem;">Tamamlandı</span>
                                        </div>
                                        <div class="small fw-bold text-dark mb-1">@islem.MalzemeAciklamasi</div>
                                        <div class="d-flex justify-content-between small text-muted" style="font-size: 0.68rem;">
                                            <span>Üretilen:</span><span class="fw-bold text-success">@islem.Miktar Adet ✓</span>
                                        </div>
                                        <div class="text-muted mt-1" style="font-size: 0.65rem;">
                                            <i class="bi bi-clock me-1"></i>@islem.IslemZamani.ToString("dd.MM HH:mm")
                                        </div>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ORGANİZASYON -->
        <div class="col-md-3">
            <div class="card h-100 border-0 shadow-sm d-flex flex-column" style="border-left: 5px solid #f39c12 !important;">
                <div class="card-body p-3 d-flex flex-column justify-content-between">
                    <div>
                        <h6 class="card-title text-uppercase fw-bold mb-2" style="color:#f39c12; font-size:0.78rem;"><i class="bi bi-people-fill me-1"></i>Organizasyon</h6>
                        <div class="mb-2">
                            <span class="text-primary fw-bold fs-6" id="activeShift">Gündüz Vardiyası</span><br>
                            <span class="text-muted" style="font-size: 0.75rem;">Etiketleme Amirliği Nöbetçi Ekip</span>
                        </div>
                        <div class="p-1 bg-light rounded text-center text-dark fw-bold mb-3" style="border: 1px dashed #f39c12; font-size: 0.75rem;">
                            State-Transfer Aktif
                        </div>
                    </div>
                    <button class="btn btn-sm w-100 mt-auto" style="background-color: #f39c12; color: #fff; font-weight: bold; font-size: 0.8rem;" onclick="showShiftTeam()">
                        <i class="bi bi-people-fill me-1"></i> Aktif Ekip
                    </button>
                </div>
            </div>
        </div>
    </div>

    
    <div class="row">
        <div class="col-xl-12">
            <div class="card border-0 shadow-sm w-100 d-flex flex-column">
