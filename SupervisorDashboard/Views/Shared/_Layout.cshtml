<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SmartLogistics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body style="background-color: #f4f6f9;">

    <nav class="navbar navbar-expand-lg shadow-sm px-4 py-2 mb-0" style="background-color: #2b3e50;">
        <a class="navbar-brand text-white fw-bold" href="/">
            <i class="bi bi-activity me-2"></i>SmartLogistics
        </a>
        <div class="ms-auto d-flex gap-2">
            <a href="/" class="btn btn-sm btn-outline-light">
                <i class="bi bi-house-fill me-1"></i> Kontrol Merkezi
            </a>
            <a href="/MamulDepo" class="btn btn-sm" style="background-color: #8e44ad; color: #fff;">
                <i class="bi bi-archive-fill me-1"></i> Mamül Depo
            </a>
        </div>
    </nav>

    <div class="container-fluid py-3">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>